{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git stash list)",
      "Bash(git stash list*)",
      "Bash(git ls-files*)",
      "Bash(git ls-tree*)",
      "Bash(git check-ignore*)",
      "Bash(git show*)",
      "Bash(git fetch*)",
      "Bash(git remote get-url*)",
      "Bash(git config --list*)",
      "Bash(git rev-parse*)",
      "Bash(git worktree list*)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(npm run build*)",
      "Bash(npx tsc*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(ls*)",
      "Bash(du -sh*)",
      "Bash(cat /home/user/remax-boss-v2/*)",
      "Bash(echo*)",
      "Bash(grep*)"
    ]
  }
}
