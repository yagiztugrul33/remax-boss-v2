# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic API (Claude) — AI sohbet asistanı ---
# Server-only (NEXT_PUBLIC YOK) → anahtar client'a sızmaz.
# Boş bırakılırsa /api/chat 503 döner. Vercel project settings → Environment
# Variables üzerinden ekle ve "Sensitive" işaretle.
ANTHROPIC_API_KEY=
# Model override — opsiyonel. Boşsa default: claude-haiku-4-5
ANTHROPIC_MODEL=

# --- AI sohbet asistanı feature flag ---
# Bu flag "true" değilse hem UI render edilmez hem /api/chat 503 döner.
# Default (boş) → KAPALI. Aktive için Vercel'e bu flag'i "true" olarak ekle
# + ANTHROPIC_API_KEY ekle + redeploy.
NEXT_PUBLIC_AI_ASSISTANT_ENABLED=

# --- Mapbox ---
NEXT_PUBLIC_MAPBOX_TOKEN=
